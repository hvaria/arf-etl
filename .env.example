# ── Database ──────────────────────────────────────────────────────────────────
# Full path to the SQLite database file.
# Local dev: leave as-is (writes to ./data.db in this directory)
# Fly.io:    /data/data.db  (the persistent volume mount path)
DATABASE_PATH=./data.db

# ── ETL behaviour ─────────────────────────────────────────────────────────────
NODE_ENV=development

# Limit records processed (0 = all). Useful for smoke-testing.
# ETL_LIMIT=100

# Enrichment rate limiter — CCLD Transparency API requests per second.
# ETL_RPS=5

# Restrict enrichment to specific counties (comma-separated).
# ETL_COUNTIES=Sacramento,San Diego
